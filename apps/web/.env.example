# ─────────────────────────────────────────────────────────────────────────────
# AXOS OS — apps/web environment variables (example)
#
# Copy to `.env.local` and fill in. Variables WITHOUT the NEXT_PUBLIC_ prefix
# are server-side only (never shipped to the browser). Variables WITH the
# NEXT_PUBLIC_ prefix ARE exposed to the browser — never put secrets there.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend connectivity (server-side) ───────────────────────────────────────
# Base URL the web server uses to reach the NestJS backend (server-to-server).
# Falls back to NEXT_PUBLIC_API_URL, then http://localhost:3000.
BACKEND_INTERNAL_URL=http://localhost:3000
# Backend API URL exposed to the browser (client-side fetches).
NEXT_PUBLIC_API_URL=http://localhost:3000
# Backend URL used by the t-code (transaction) routes. Defaults to :3001.
API_URL=http://localhost:3001
# Shared key sent as the `x-frontend-key` header to the backend. Must match the
# backend's configured value. Leave empty to omit the header.
FRONTEND_SHARED_KEY=

# ── Backend service account (server-side) ────────────────────────────────────
# Credentials the web server uses for user management + the bridge fallback.
# BACKEND_SERVICE_PASSWORD is MANDATORY in production (the app throws if it is
# missing — there is no public default). Must match the backend's value
# (apps/api/src/common/config/service-password.ts).
BACKEND_SERVICE_EMAIL=admin@example.com
BACKEND_SERVICE_PASSWORD=

# ── Session (server-side) ─────────────────────────────────────────────────────
# Secret used to sign session cookies. Set a long random value in production;
# the built-in dev fallback is insecure and must NOT be used in prod.
AXOS_SESSION_SECRET=

# ── Optional demo admin for the local file store (server-side) ────────────────
# If DEMO_ADMIN_PASSWORD is set, a read-only demo admin (role: executive) is
# seeded into the local file store (apps/web/data/store.json) on first use.
# If it is UNSET, NO demo account is created — fail-safe, never a hardcoded
# password. Do NOT give this a NEXT_PUBLIC_ prefix; it must stay server-side.
# Note: the credential-less demo path (POST /api/auth/demo) does not need this.
DEMO_ADMIN_PASSWORD=
# Optional email for that demo admin. Defaults to admin@axos.com.
DEMO_ADMIN_EMAIL=admin@axos.com

# ── Access-control hints (browser) ────────────────────────────────────────────
# Frontend hint of the master-admin email (mirrors the backend's MASTER_ADMIN_EMAIL).
NEXT_PUBLIC_MASTER_ADMIN_EMAIL=
# Comma-separated list of EXTRA owner emails. Only ADDS owners; never removes
# the built-in defaults.
NEXT_PUBLIC_OWNER_EMAILS=

# ── Integrations (browser) ────────────────────────────────────────────────────
# Giphy API key for stickers / GIFs in messaging.
NEXT_PUBLIC_GIPHY_KEY=
# WebRTC TURN server for voice/video calls.
NEXT_PUBLIC_TURN_URL=
NEXT_PUBLIC_TURN_USERNAME=
NEXT_PUBLIC_TURN_CREDENTIAL=
