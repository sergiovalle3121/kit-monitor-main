# Playwright artifacts (kept out of git without touching the repo-root .gitignore)
.test-results/
.report/
.cache/

# Barrido visual: los screenshots (pesados, a cualquier profundidad) quedan
# fuera de git; el JSON de hallazgos (visual-findings.json) SÍ se versiona. Las
# muestras antes/después curadas se versionan aparte en docs/visual-qa/.
__visual__/**/*.png
__visual__/**/*.jpeg
