# Backend environment
NODE_ENV=production
PORT=3000
ALLOWED_ORIGIN=https://axonos.up.railway.app
FRONTEND_SHARED_KEY=change-me-strong-key

# Railway Postgres (reemplaza host/credenciales con los de Railway)
DATABASE_URL=postgresql://postgres:password@host:5432/railway?sslmode=require

# JWT Secret - IMPORTANT: Change this in production!
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Dev (opcional):
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=postgres
# DB_PASSWORD=postgres
# DB_DATABASE=kitmonitor
# SYNCHRONIZE=false

# ── Admins ───────────────────────────────────────────────────────────────────
# Master admin (opcional): habilita un admin humano por env (idempotente).
# MASTER_ADMIN_EMAIL=tu-correo@dominio.com
# MASTER_ADMIN_PASSWORD=cambia-esto
# MASTER_ADMIN_NAME=Tu Nombre
#
# Owner admin(s): SIEMPRE se aseguran como Admin en cada arranque (el dueño puede
# entrar aunque no haya MASTER_ADMIN_*). El correo es identidad, no secreto.
# Por defecto incluye al dueño del producto; sepáralos por comas para añadir más.
# OWNER_ADMIN_EMAILS=sergiovallezarate@gmail.com
# OWNER_ADMIN_NAME=Owner
# OWNER_ADMIN_PASSWORD=        # si se define, es la fuente de verdad de la contraseña;
                               # si no, en el primer arranque usa BACKEND_SERVICE_PASSWORD.
#
# Cuenta de servicio (fallback del puente frontend → backend):
# BACKEND_SERVICE_EMAIL=admin@example.com
# BACKEND_SERVICE_PASSWORD=31218223

# ── Axos AI Copilot ──────────────────────────────────────────────────────────
# Llave de plataforma de Anthropic (pago por uso vía console.anthropic.com).
# NOTA: el plan Claude Pro/Max NO cubre el uso por API de la app; es facturación aparte.
# ANTHROPIC_API_KEY=sk-ant-...
# Secreto para cifrar las llaves BYO de cada organización (usa JWT_SECRET si no se define).
# AI_KEY_SECRET=cambia-esto-cadena-larga
# Tope de tokens de salida por turno (principal control de costo). Default 700.
# AI_MAX_OUTPUT_TOKENS=700
# Presupuesto mensual de tokens por defecto para organizaciones nuevas. Default 1000000.
# AI_DEFAULT_MONTHLY_BUDGET_TOKENS=1000000
# Modo demo sin costo (respuestas simuladas, no llama a la API). 1 = activado.
# AI_MOCK=0
