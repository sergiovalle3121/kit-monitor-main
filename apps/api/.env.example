# Backend environment
NODE_ENV=production
PORT=3000
ALLOWED_ORIGIN=https://axonos.up.railway.app
FRONTEND_SHARED_KEY=change-me-strong-key

# Railway Postgres (reemplaza host/credenciales con los de Railway)
DATABASE_URL=postgresql://postgres:password@host:5432/railway?sslmode=require

# JWT Secret - IMPORTANT: Change this in production!
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Dev (opcional):
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=postgres
# DB_PASSWORD=postgres
# DB_DATABASE=kitmonitor
# SYNCHRONIZE=false

# ── Admins ───────────────────────────────────────────────────────────────────
# Master admin (opcional): habilita un admin humano por env (idempotente).
# MASTER_ADMIN_EMAIL=tu-correo@dominio.com
# MASTER_ADMIN_PASSWORD=cambia-esto
# MASTER_ADMIN_NAME=Tu Nombre
#
# Owner admin(s): SIEMPRE se aseguran como Admin en cada arranque (el dueño puede
# entrar aunque no haya MASTER_ADMIN_*). El correo es identidad, no secreto.
# Por defecto incluye al dueño del producto; sepáralos por comas para añadir más.
# OWNER_ADMIN_EMAILS=sergiovallezarate@gmail.com
# OWNER_ADMIN_NAME=Owner
# OWNER_ADMIN_PASSWORD=        # fuente de verdad de la contraseña del owner. OBLIGATORIA
                               # en prod si no defines BACKEND_SERVICE_PASSWORD; si no se
                               # define, en el primer arranque se usa BACKEND_SERVICE_PASSWORD.
#
# Cuenta de servicio (puente frontend → backend). OBLIGATORIA en producción:
# el backend NO arranca en prod (NODE_ENV=production o DATABASE_URL presente) si
# falta — fail-closed, sin defaults públicos. En dev local (SQLite/sin DATABASE_URL)
# se usa el placeholder 'dev-only-change-me'. Debe COINCIDIR en backend (apps/api)
# y frontend (apps/web). Define una contraseña fuerte; NUNCA uses un valor de ejemplo.
# BACKEND_SERVICE_EMAIL=admin@example.com
# BACKEND_SERVICE_PASSWORD=

# ── CIDE — IA propia (self-hosted, open-source) ───────────────────────────────
# CIDE corre sobre un motor de inferencia compatible-OpenAI que TÚ controlas
# (Ollama/vLLM/llama.cpp). No usa ningún proveedor externo de IA; los datos
# nunca salen de tu infraestructura.
#
# Local (desarrollo):
#   docker compose -f infra/cide/docker-compose.yml up -d
#   docker exec -it cide-ollama ollama pull qwen2.5:7b
#
# Railway (producción, CPU): despliega infra/cide (Dockerfile incluido) como un
# servicio aparte — arranca Ollama, expone :11434 y descarga el modelo solo.
# Luego apunta ESTA API a su URL PRIVADA de Railway (no la pública):
#   CIDE_BASE_URL=http://<nombre-servicio-cide>.railway.internal:11434/v1
#   AI_MOCK=0
# Verifica desde /dashboard/admin/ai → "Probar conexión".
#
# GPU (producción rápida, vLLM): en un host con GPU NVIDIA,
#   docker compose -f infra/cide/docker-compose.gpu.yml up -d
# Mismo API compatible-OpenAI ⇒ solo cambia la URL (cero código):
#   CIDE_BASE_URL=http://<host-gpu>:8000/v1
# Detalles y hosts gestionados (RunPod/Lambda) en infra/cide/README.md.
#
# URL del motor compatible-OpenAI. Default = Ollama local.
# CIDE_BASE_URL=http://localhost:11434/v1
# Token bearer del motor (solo si tu motor lo exige; Ollama local no lo necesita).
# CIDE_API_KEY=
# Modelo por defecto (debe estar en el catálogo). En CPU puro, qwen2.5:1.5b va
# más fluido; con GPU sube a qwen2.5:14b. Default qwen2.5:7b.
# CIDE_DEFAULT_MODEL=qwen2.5:7b
# CIDE_ESCALATION_MODEL=qwen2.5:32b
# Modelos extra a registrar (coma-separados): served-model-names de vLLM/TGI o
# ids de HuggingFace, para apuntar a cualquier motor sin tocar código. Mantén
# licencias permisivas (Apache-2.0/MIT/BSD) — Qwen2.5-3B y -72B NO son Apache-2.0.
# CIDE_EXTRA_MODELS=Qwen/Qwen2.5-14B-Instruct
# Timeout por petición al motor (ms). Súbelo si corres en CPU lento. Default 120000.
# CIDE_TIMEOUT_MS=120000
# Tope de tokens de salida por turno. Default 1500 (respuestas ricas estilo chat).
# AI_MAX_OUTPUT_TOKENS=1500
# Guardia mensual de uso (tokens) por defecto para organizaciones nuevas. Default 1000000.
# AI_DEFAULT_MONTHLY_BUDGET_TOKENS=1000000
# Modo demo: ejecuta las herramientas reales pero no llama al motor. 1 = activado.
# AI_MOCK=0
# Briefing proactivo: CIDE empuja a los admins el resumen diario cuando hay alertas.
# Apágalo con CIDE_BRIEF_PUSH_ENABLED=false; ajusta el horario con un cron.
# CIDE_BRIEF_PUSH_ENABLED=true
# CIDE_BRIEF_PUSH_CRON=0 7 * * *
