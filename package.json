{
  "name": "axos-os",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "start": "turbo run start --filter=web",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "turbo": "latest",
