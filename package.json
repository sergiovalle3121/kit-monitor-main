{
  "name": "axos-os",
  "private": true,
  "packageManager": "npm@10.9.3",
  "engines": {
    "node": ">=20.9.0",
    "npm": ">=10"
  },
  "scripts": {
    "build": "npx turbo run build",
    "start": "npm run start --workspace=web",
    "dev": "npx turbo run dev",
    "lint": "npx turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "turbo": "latest",
    "prettier": "^3.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
